        },
        {
          "id": "C01_end",
          "type": "end",
          "nextScene": "GameScene",
          "fadeOutDuration": 1500
        }
      ]
    },
    {
      "id": "C02",
      "name": "第一株甘草",
      "type": "scene",
      "background": "bg_plains_road.png",
      "bgm": "bgm_journey.mp3",
      "_trigger": {
        "type": "zone",
        "zoneId": "zone_first_herbs",
        "once": true,
        "dialogType": "bubble",
        "eventId": "EVT_FIRST_HERB"
      },
      "steps": [
        {
          "id": "C02_001",
          "type": "dialogue",
          "character": "qingmiao",
          "expression": "happy",
          "name": "青苗",
          "text": "主人！甘草！路边就有！快采！",
          "avatar": "qingmiao.png",
          "nextDelay": 300
        },
        {
          "id": "C02_002",
          "type": "tutorial",
          "tutorialAction": "collect_gancao",
          "herbId": "gancao",
          "requiredCount": 2,
          "hint": "采集路旁甘草 ×2（靠近后按 E）",
          "nextDelay": 0
        }
      ]
    },
    {
      "id": "C03",
      "name": "砍柴老汉问路",
      "type": "dialogue",
      "background": "bg_plains_road.png",
      "bgm": "bgm_journey.mp3",
      "_trigger": {
        "type": "npc",
        "npcId": "woodcutter_npc",
        "once": false,
        "dialogType": "overlay",
        "eventId": "EVT_WOODCUTTER"
      },
      "steps": [
        {
          "id": "C03_001",
          "type": "dialogue",
          "character": "woodcutter",
          "expression": "normal",
          "name": "砍柴老伯",
          "text": "（停下斧头，打量你）咦，背着药囊的……是大夫？打哪儿来？",
          "avatar": "woodcutter.png",
          "nextDelay": 500
        },
        {
          "id": "C03_choice1",
          "type": "choice",
          "options": [
            {
              "text": "「岐黄学堂来的，去翠竹村给人看病。」",
              "flag": "told_purpose",
              "response": {
                "type": "dialogue",
                "character": "woodcutter",
                "expression": "normal",
                "name": "砍柴老伯",
                "text": "哎！好！翠竹村啊，那边可需要大夫！往南走，看见那片竹林向右拐，看见牌坊就是了。村里好些老人病着呢。",
                "avatar": "woodcutter.png",
                "nextDelay": 500,
                "nextStep": "C03_002"
              }
            },
            {
              "text": "「请问翠竹村怎么走？」",
              "flag": "asked_directions",
              "response": {
                "type": "dialogue",
                "character": "woodcutter",
                "expression": "normal",
                "name": "砍柴老伯",
                "text": "翠竹村？就在南边，竹林旁边。你走路的话，小半个时辰就到了——对了，你是大夫吗？那边正缺人哩！",
                "avatar": "woodcutter.png",
                "nextDelay": 500,
                "nextStep": "C03_002"
              }
            }
          ]
        },
        {
          "id": "C03_002",
          "type": "dialogue",
          "character": "woodcutter",
          "expression": "normal",
          "name": "砍柴老伯",
          "text": "（指着南方）路上草药多，顺手采些带着。这条路的甘草最好，我家老伴年年来摘。",
          "avatar": "woodcutter.png",
          "nextDelay": 500
        }
      ]
    },
    {
      "id": "C04",
      "name": "废弃草药篓",
      "type": "scene",
      "background": "bg_plains_woods.png",
      "bgm": "bgm_journey.mp3",
      "_trigger": {
        "type": "object",
        "objectId": "abandoned_basket",
        "once": true,
        "dialogType": "bubble",
        "eventId": "EVT_ABANDONED_BASKET"
      },
      "steps": [
        {
          "id": "C04_001",
          "type": "dialogue",
          "character": "narrator",
          "name": "旁白",
          "text": "（检查）一只遗落的竹编药篓，已经半朽，里面残留着几片干枯的叶片——像是金银花，但已辨认不清。",
          "nextDelay": 1500
        },
        {
          "id": "C04_002",
          "type": "dialogue",
          "character": "qingmiao",
          "expression": "surprised",
          "name": "青苗",
          "text": "（凑近嗅一嗅）……有人最近来过这里采药，但是放弃了。气味……有点不对。不像是自然枯萎。",
          "avatar": "qingmiao.png",
          "nextDelay": 500,
          "setFlag": "clue_herbs_dying"
        }
      ]
    },
    {
      "id": "C05",
      "name": "洗衣村妇",
      "type": "dialogue",
      "background": "bg_plains_river.png",
      "bgm": "bgm_journey.mp3",
      "_trigger": {
        "type": "npc",
        "npcId": "washerwoman_npc",
        "once": false,
        "dialogType": "overlay",
        "eventId": "EVT_WASHERWOMAN"
      },
      "steps": [
        {
          "id": "C05_001",
          "type": "dialogue",
          "character": "washerwoman",
          "expression": "normal",
          "name": "洗衣妇",
          "text": "（抬头）哎，外乡来的？去翠竹村？那里可惨了……村里老人一个接一个倒，药铺又没货，大夫又请不来……",
          "avatar": "washerwoman.png",
          "nextDelay": 500
        },
        {
          "id": "C05_002",
          "type": "dialogue",
          "character": "washerwoman",
          "expression": "normal",
          "name": "洗衣妇",
          "text": "（压低声音）我倒是听村里人说，从入秋起，南边草场长了种怪草，灰绿色的，那之后药材就越来越少……可别去踩那东西，晦气。",
          "avatar": "washerwoman.png",
          "nextDelay": 500,
          "setFlag": "clue_gugen_early"
        },
        {
          "id": "C05_003",
          "type": "dialogue",
          "character": "qingmiao",
          "expression": "surprised",
          "name": "青苗",
          "text": "（小声对主人）主人……蛊根草从这里就开始了？",
          "avatar": "qingmiao.png",
          "nextDelay": 500
        }
      ]
    },
    {
      "id": "C06",
      "name": "行商王掌柜",
      "type": "dialogue",
      "background": "bg_plains_south.png",
      "bgm": "bgm_journey.mp3",
      "_trigger": {
        "type": "npc",
        "npcId": "merchant_npc",
        "once": false,
        "dialogType": "overlay",
        "eventId": "EVT_MERCHANT"
      },
      "steps": [
        {
          "id": "C06_001",
          "type": "dialogue",
          "character": "merchant",
          "expression": "normal",
          "name": "行商 王掌柜",
          "text": "（招手）哎，小大夫，背囊里有草药不？这一带草药紧俏，我收购！",
          "avatar": "merchant.png",
          "nextDelay": 500
        },
        {
          "id": "C06_choice1",
          "type": "choice",
          "options": [
            {
              "text": "「我自己要用，暂不出售。」",
              "flag": "declined_merchant",
              "response": {
                "type": "dialogue",
                "character": "merchant",
                "expression": "normal",
                "name": "行商 王掌柜",
                "text": "哦，自己用的。行，那到了翠竹村，若有余货，村东头药铺找我——对了，那药铺现在没掌柜，等新大夫来了才能开。",
                "avatar": "merchant.png",
                "nextDelay": 500,
                "nextStep": "C06_002"
              }
            },
            {
              "text": "「价格怎么样？」",
              "flag": "asked_price",
              "response": {
                "type": "dialogue",
                "character": "merchant",
                "expression": "normal",
                "name": "行商 王掌柜",
                "text": "甘草三文一株，菊花五文，金银花十五文一束——金银花现在稀少，价格涨了。你若攒够一批，合算。",
                "avatar": "merchant.png",
                "nextDelay": 500,
                "nextStep": "C06_002"
              }
            }
          ]
        },
        {
          "id": "C06_002",
          "type": "tutorial",
          "tutorialAction": "shop_price_hint",
          "hint": "草药可在药铺出售获得铜钱！\n稀有草药售价更高，留意节气采集时机",
          "hintPosition": "top-center",
          "nextDelay": 0
        }
      ]
    },
    {
      "id": "C07",
      "name": "翠竹村牌坊",
      "type": "scene",
      "background": "bg_village_gate.png",
      "bgm": "bgm_village.mp3",
      "autoChainToNext": true,
      "_trigger": {
        "type": "zone",
        "zoneId": "zone_village_gate",
        "once": true,
        "dialogType": "overlay",
        "eventId": "EVT_VILLAGE_GATE"
      },
      "steps": [
        {
          "id": "C07_001",
          "type": "narration",
          "text": "竹林尽头，一座石牌坊出现在眼前——「翠竹村」三字苍劲古朴，石缝间爬满青苔。",
          "nextDelay": 2500
        },
        {
          "id": "C07_002",
          "type": "dialogue",
          "character": "qingmiao",
          "expression": "happy",
          "name": "青苗",
          "text": "到了！到了！主人，村里有好多人的气息……还有草药！还有……（停顿）……还有一种说不清楚的怪味。",
          "avatar": "qingmiao.png",
          "nextDelay": 500
        },
        {
          "id": "C07_003",
          "type": "narration",
          "text": "一个身材魁梧、面色憨厚的老汉从牌坊后绕出来，一见你便大步迎上。",
          "nextDelay": 1500
        }
      ]
    },
    {
      "id": "C08",
      "name": "村长接委托",
      "type": "dialogue",
      "background": "bg_village_entrance.png",
      "bgm": "bgm_village.mp3",
      "_trigger": {
        "type": "zone",
        "zoneId": "zone_village_entrance",
        "once": true,
        "dialogType": "overlay",
        "eventId": "EVT_CUNZHANG_INTRO",
        "locComplete": null
      },
      "steps": [
        {
          "id": "C08_001",
          "type": "dialogue",
          "character": "cunzhang",
          "expression": "happy",
          "name": "村长 张老汉",
          "text": "（搓手）哎呀！岐黄学堂来的吧！小兰托人捎话说要来，我等了你大半天！快快快，进村！",
          "avatar": "village_chief.png",
          "nextDelay": 500
        },
        {
          "id": "C08_002",
          "type": "dialogue",
          "character": "cunzhang",
          "expression": "worried",
          "name": "村长 张老汉",
          "text": "村里这两个月啊，老人们一个个倒下——四肢乏力，咳嗽不止。药铺早断货，镇上大夫又请不来……",
          "avatar": "village_chief.png",
          "nextDelay": 500
        },
        {
          "id": "C08_003",
          "type": "dialogue",
          "character": "cunzhang",
          "expression": "serious",
          "name": "村长 张老汉",
          "text": "村东头有间空铺子，你若愿意留下行医，那铺子免费借你！你治病，我们守铺子，怎么说？",
          "avatar": "village_chief.png",
          "nextDelay": 500
        },
        {
          "id": "C08_choice1",
          "type": "choice",
          "options": [
            {
              "text": "「成交！翠竹村的大夫，从今天起是我了！」",
              "flag": "accept_village",
              "response": {
                "type": "dialogue",
                "character": "cunzhang",
                "expression": "happy",
                "name": "村长 张老汉",
                "text": "哈哈！好！先四处走走，认认路，认认人。村子不大，一圈下来一盏茶工夫。去跟老李、张大娘他们说说话，了解情况。",
                "avatar": "village_chief.png",
                "nextDelay": 500,
                "nextStep": "C08_004"
              }
            },
            {
              "text": "「先看看情况再说。」",
              "flag": "cautious_arrival",
              "response": {
                "type": "dialogue",
                "character": "cunzhang",
                "expression": "happy",
                "name": "村长 张老汉",
                "text": "行，稳当。先四处走走，认认路认认人，铺子的事之后再谈。村里几处你都去看看。",
                "avatar": "village_chief.png",
                "nextDelay": 500,
                "nextStep": "C08_004"
              }
            }
          ]
        },
        {
          "id": "C08_004",
          "type": "tutorial",
          "tutorialAction": "village_explore",
          "hint": "探索翠竹村！\n地图上「！」标记处有可交互对象\n完成全部 5 处地点后推进主线",
          "hintPosition": "top-center",
          "nextDelay": 0
        },
        {
          "id": "C08_village_map",
          "type": "show_village_map",
          "mapImage": "village_map_full",
          "hint": "点击地图上的地点标记进行探索"
        }
      ]
    },
    {
      "id": "C09",
      "name": "草药圃辨药",
      "type": "dialogue",
      "background": "bg_herb_garden.png",
      "bgm": "bgm_village.mp3",
      "_trigger": {
        "type": "npc",
        "npcId": "laoli_npc",
        "once": false,
        "locComplete": "loc_herb_garden",
        "eventId": "EVT_LAOLI_HERB_GARDEN"
      },
      "steps": [
        {
          "id": "C09_001",
          "type": "dialogue",
          "character": "laoli",
          "expression": "normal",
          "name": "药农 老李",
          "text": "（蹲在药圃边，抬起头）哟，学堂来的。这一圃本来种的是甘草、山药、紫苏……现在都蔫儿了，也不知是土的问题还是那怪草闹的。",
          "avatar": "laoli.png",
          "nextDelay": 500
        },
        {
          "id": "C09_002",
          "type": "dialogue",
          "character": "laoli",
          "expression": "normal",
          "name": "药农 老李",
          "text": "你既然是大夫，来帮我认认——这三株里头，哪株是金银花？",
          "avatar": "laoli.png",
          "nextDelay": 500
        },
        {
          "id": "C09_minigame",
          "type": "minigame_flower_id",
          "flowerData": {
            "correctAnswer": "jinyinhua",
            "instructions": "三花选一，找出金银花"
          },
          "rewardOnCorrect": {
            "attr": "herb_knowledge",
            "delta": 3
          },
          "nextDelay": 500
        },
        {
          "id": "C09_003",
          "type": "dialogue",
          "character": "laoli",
          "expression": "normal",
          "name": "药农 老李",
          "text": "（压低声音）说句心里话……村南那片蛊根草，老汉我见过一次，在深山里。那东西的根，会向土里分泌什么，周围草药全扎不住根。我爷爷说，大草纪二百年那场大疫之前，也出现过。",
          "avatar": "laoli.png",
          "nextDelay": 500,
          "setFlag": "clue_gugen_history"
        },
        {
          "id": "C09_reward",
          "type": "reward",
          "items": [
            {
              "id": "jinyinhua",
              "name": "金银花",
              "count": 3,
              "icon": "🌸"
            }
          ],
          "nextDelay": 800
        }
      ]
    },
    {
      "id": "C10",
      "name": "水井边病情线索",
      "type": "dialogue",
      "background": "bg_village_well.png",
      "bgm": "bgm_village.mp3",
      "_trigger": {
        "type": "npc",
        "npcId": "well_villager_npc",
        "once": false,
        "locComplete": "loc_well",
        "eventId": "EVT_WELL_VILLAGER"
      },
      "steps": [
        {
          "id": "C10_001",
          "type": "dialogue",
          "character": "villager_b",
          "expression": "normal",
          "name": "村民 陈大嫂",
          "text": "（打完水，叹气）大夫来了就好……我家老娘三天没下床，腰酸腿软，气都喘不上来。",
          "avatar": "villager_b.png",
          "nextDelay": 500
        },
        {
          "id": "C10_002",
          "type": "dialogue",
          "character": "villager_b",
          "expression": "normal",
          "name": "村民 陈大嫂",
          "text": "不只我家，隔壁王老伯、李奶奶都一样——乏力、夜咳、腰酸，症状差不多。入秋后就开始的，和那蛊根草出现的时间对得上……",
          "avatar": "villager_b.png",
          "nextDelay": 500,
          "setFlag": "clue_mass_symptom"
        },
        {
          "id": "C10_003",
          "type": "dialogue",
          "character": "qingmiao",
          "expression": "surprised",
          "name": "青苗",
          "text": "（认真地听着，小声对主人）乏力、夜咳、腰酸……主人，这像是肺和肾的问题。",
          "avatar": "qingmiao.png",
          "nextDelay": 500
        }
      ]
    },
    {
      "id": "C11",
      "name": "晒药台炮制教程",
      "type": "dialogue",
      "background": "bg_drying_platform.png",
      "bgm": "bgm_village.mp3",
      "_trigger": {
        "type": "object",
        "objectId": "drying_platform_obj",
        "once": true,
        "locComplete": "loc_drying_platform",
        "eventId": "EVT_DRYING_PLATFORM"
      },
      "steps": [
        {
          "id": "C11_001",
          "type": "dialogue",
          "character": "narrator",
          "name": "旁白",
          "text": "（检查）一张空置的竹编晒药匾，积了一层薄灰——看来已经很久没人用了。",
          "nextDelay": 1500
        },
        {
          "id": "C11_002",
          "type": "dialogue",
          "character": "laoli",
          "expression": "normal",
          "name": "药农 老李",
          "text": "（路过，停下来）那是晒药匾。你背包里有菊花吗？这时候正好晒——来，我教你两手。",
          "avatar": "laoli.png",
          "nextDelay": 500
        },
        {
          "id": "C11_minigame",
          "type": "minigame_dry_flower",
          "dryData": {
            "herbName": "菊花",
            "totalFlowers": 5
          },
          "rewardOnCorrect": {
            "attr": "herb_knowledge",
            "delta": 2
          },
          "nextDelay": 500
        },
        {
          "id": "C11_003",
          "type": "dialogue",
          "character": "laoli",
          "expression": "normal",
          "name": "药农 老李",
          "text": "炮制讲究「依法修治」——晾晒是最基础的一道。以后蜜炙、醋制慢慢学，急不来。",
          "avatar": "laoli.png",
          "nextDelay": 500
        },
        {
          "id": "C11_reward",
          "type": "reward",
          "items": [
            {
              "id": "juhua",
              "name": "晒菊花",
              "count": 1,
              "icon": "🌼"
            }
          ],
          "nextDelay": 800
        }
