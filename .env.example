# 环境变量配置示例
# 复制此文件为 .env 并填写真实API Key

# 服务器端口
PORT=3000

# LLM API配置
# 可选值: claude | gpt | tencent
LLM_PROVIDER=claude

# Claude API Key (推荐)
LLM_API_KEY=your_claude_api_key_here

# GPT API Key (备选)
# LLM_API_KEY=your_openai_api_key_here

# 腾讯云混元 API Key (备选)
# LLM_PROVIDER=tencent
# TENCENT_SECRET_ID=your_secret_id_here
# TENCENT_SECRET_KEY=your_secret_key_here

# 游戏配置
GAME_VERSION=1.0.0
DEBUG_MODE=true

# 数据库配置 (未来扩展)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=baicaoxing
# DB_USER=postgres
# DB_PASSWORD=password
